{
  "name": "cloudflare-worker-mcp",
  "private": true,
  "version": "0.1.0",
  "description": "Cloudflare Worker MCP server for the Cloudflare API using Worker Loader",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "types": "wrangler types",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "seed": "tsx scripts/seed-r2.ts"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "hono": "^4.12.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.4",
    "@types/node": "^25.0.6",
    "oxfmt": "^0.31.0",
    "oxlint": "^1.46.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "3.2",
    "wrangler": "^4.77.0"
  }
}
